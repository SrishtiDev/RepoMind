# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Google Gemini ────────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
# Optional: only needed if your Qdrant instance has API key auth enabled
# QDRANT_API_KEY=your_qdrant_api_key_here

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# Optional: set if Redis requires a password
# REDIS_PASSWORD=your_redis_password_here

# ─── Ingestion ────────────────────────────────────────────────────────────────
# Temporary directory for cloned repositories (absolute path recommended)
CLONE_BASE_DIR=/tmp/repomind_repos

# BullMQ queue name
QUEUE_NAME=ingestion
